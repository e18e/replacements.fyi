{
	"name": "module-replacements-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"clear-build": "rm -rf ./.svelte-kit/cloudflare",
		"dev": "vite dev",
		"build": "pnpm clear-build && wrangler types --check && vite build",
		"preview": "wrangler dev",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "pnpm run test:unit -- --run && pnpm run test:e2e",
		"test:e2e": "playwright test",
		"gen": "pnpm clear-build && wrangler types",
		"deploy": "pnpm run build && wrangler deploy --env=\"\"",
		"deploy:preview": "pnpm run build && wrangler versions --env=\"\" upload"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@eslint/js": "^10.0.1",
		"@playwright/test": "^1.61.1",
		"@remix-run/route-pattern": "^0.23.0",
		"@sveltejs/adapter-cloudflare": "^7.2.9",
		"@sveltejs/kit": "^2.69.1",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@types/node": "^26",
		"@vitest/browser-playwright": "^4.1.9",
		"eslint": "^10.6.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"globals": "^17.7.0",
		"playwright": "^1.61.1",
		"prettier": "^3.9.4",
		"prettier-plugin-svelte": "^4.1.1",
		"shiki": "^4.3.0",
		"svelte": "^5.56.4",
		"svelte-check": "^4.7.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.62.1",
		"vite": "^8.1.3",
		"vitest": "^4.1.9",
		"vitest-browser-svelte": "^2.2.0",
		"wrangler": "^4.107.0"
	},
	"dependencies": {
		"@fontsource/ibm-plex-mono": "^5.2.7",
		"module-replacements": "3.0.0-beta.8",
		"sveltekit-view-transition": "^0.5.3",
		"valibot": "^1.4.2"
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
